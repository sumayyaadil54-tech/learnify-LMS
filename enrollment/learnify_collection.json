		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"teststudent\",\n    \"email\": \"student@learnify.com\",\n    \"password\": \"password123\",\n    \"role\": \"student\",\n    \"phone\": \"1234567890\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/users/register/",
							"host": ["{{base_url}}"],
							"path": ["users", "register", ""]
						},
						"description": "Registers a new user account (Student/Instructor) to the Learnify platform."
					}
				},
				{
					"name": "Login User",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"teststudent\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/users/login/",
							"host": ["{{base_url}}"],
							"path": ["users", "login", ""]
						},
						"description": "Authenticates user credentials and returns a token or session."
					}
				}
			]
		},
